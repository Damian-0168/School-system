// Prisma Schema for Dominion School Management System
// Database: MySQL 8.0+
// ORM: Prisma
// Version: 2.0 - With enums, relations, indices, and audit improvements

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Gender {
  M
  F
}

enum StudentStatus {
  ACTIVE
  PROMOTED
  WITHDRAWN
}

enum UserRole {
  ADMIN
  ACCOUNTS
  DIRECTOR
  RECEPTION
}

enum FeeTypeEnum {
  TUITION
  TRANSPORT
  STATIONERY
  ID
  EXAM
  LIBRARY
  OTHER
}

enum PaymentMethod {
  CASH
  MOBILE
  BANK
}

enum PaymentStatus {
  ACTIVE
  VOIDED
}

enum DebtStatus {
  PENDING
  PARTIAL
  PAID
}

enum InventoryStatus {
  PENDING
  FULFILLED
  ISSUED
}

enum TransportStatus {
  ACTIVE
  INACTIVE
}

enum NotificationChannel {
  SMS
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

// ==================== ACADEMIC STRUCTURE ====================

/// Academic year (e.g., 2026)
model AcademicYear {
  id         BigInt          @id @default(autoincrement())
  year       Int             @unique
  startDate  DateTime        @db.Date
  endDate    DateTime        @db.Date
  isActive   Boolean         @default(false)
  terms      AcademicTerm[]
  promotions Promotion[]
  receipts   Receipt[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([isActive])
  @@map("academic_years")
}

/// Academic term within a year (1st, 2nd, 3rd)
model AcademicTerm {
  id            BigInt          @id @default(autoincrement())
  academicYearId BigInt
  name          String          // "1st", "2nd", "3rd"
  startDate     DateTime        @db.Date
  endDate       DateTime        @db.Date
  isActive      Boolean         @default(false)
  academicYear  AcademicYear    @relation(fields: [academicYearId], references: [id])
  studentFees   StudentFee[]
  feeStructures FeeStructure[]
  payments      Payment[]
  debtRecords   DebtRecord[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([academicYearId, name])
  @@index([isActive])
  @@map("academic_terms")
}

/// Student classes (Baby, Middle, Pre-Unit, etc.)
model Class {
  id              BigInt      @id @default(autoincrement())
  name            String      @unique // "Baby Class", "Middle Class"
  sortOrder       Int         @default(0) // For custom ordering in dropdowns
  termFee         Int         // Fee per term in TZS
  annualFee       Int         // Full year fee in TZS
  students        Student[]
  feeStructures   FeeStructure[]
  fromPromotions  Promotion[] @relation("FromClass")
  toPromotions    Promotion[] @relation("ToClass")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([sortOrder])
  @@map("classes")
}

// ==================== FEE TYPES (LOOKUP) ====================

/// Fee type lookup table for flexible fee categories
model FeeType {
  id          BigInt           @id @default(autoincrement())
  name        String           @unique // "Tuition", "Transport", "Exam Fee"
  description String?          @db.Text
  isActive    Boolean          @default(true)
  structures  FeeStructure[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("fee_types")
}

// ==================== PEOPLE ====================

/// Family grouping for sibling discounts
model Family {
  id            BigInt      @id @default(autoincrement())
  familyName    String
  discountAmount Int
  discountType  String      // "fixed" or "percentage"
  guardians     Guardian[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("families")
}

/// Parent or guardian information
model Guardian {
  id               BigInt      @id @default(autoincrement())
  name             String
  phone            String
  email            String?
  address          String?
  alternateContact String?
  familyId         BigInt?
  family           Family?     @relation(fields: [familyId], references: [id])
  students         Student[]
  notifications    Notification[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([phone])
  @@index([familyId])
  @@map("guardians")
}

/// Student/pupil record
model Student {
  id            BigInt              @id @default(autoincrement())
  admissionNo   String              @unique // ADM-YYYY-###
  idPassNo      String?             // ID pass number (searchable)
  name          String
  gender        Gender
  dateOfBirth   DateTime?           @db.Date
  classId       BigInt
  guardianId    BigInt
  familyId      BigInt?
  status        StudentStatus       @default(ACTIVE)
  photoPath     String?
  deletedAt     DateTime?           // Soft delete support
  class         Class               @relation(fields: [classId], references: [id])
  guardian      Guardian            @relation(fields: [guardianId], references: [id])
  fees          StudentFee[]
  payments      Payment[]
  transport     Transport?
  inventory     StudentInventory[]
  debtRecords   DebtRecord[]
  comments      Comment[]
  promotionsFrom Promotion[]        @relation("StudentFrom")
  promotionsTo   Promotion[]        @relation("StudentTo")
  receipts       Receipt[]
  notifications  Notification[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([admissionNo])
  @@index([idPassNo])
  @@index([classId])
  @@index([guardianId])
  @@index([status])
  @@index([deletedAt])
  @@map("students")
}

/// System users (staff)
model User {
  id            BigInt        @id @default(autoincrement())
  name          String
  email         String        @unique
  role          UserRole
  passwordHash  String
  lastLogin     DateTime?
  deletedAt     DateTime?     // Soft delete support
  payments      Payment[]     @relation("RecordedBy")
  receipts      Receipt[]     @relation("IssuedBy")
  comments      Comment[]
  systemLogs    SystemLog[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("users")
}

// ==================== FEES & PAYMENTS ====================

/// Fee structure definitions per class and term
model FeeStructure {
  id              BigInt        @id @default(autoincrement())
  classId         BigInt
  academicTermId  BigInt
  feeTypeId       BigInt
  feeType         FeeType       @relation(fields: [feeTypeId], references: [id])
  amount          Int
  class           Class         @relation(fields: [classId], references: [id])
  academicTerm    AcademicTerm  @relation(fields: [academicTermId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([classId, academicTermId, feeTypeId])
  @@map("fee_structures")
}

/// Student-specific fee records per term
model StudentFee {
  id              BigInt        @id @default(autoincrement())
  studentId       BigInt
  academicTermId  BigInt
  totalAmount     Int
  discountAmount  Int           @default(0)
  netAmount       Int
  isSponsored     Boolean       @default(false)
  sponsorName     String?
  student         Student       @relation(fields: [studentId], references: [id])
  academicTerm    AcademicTerm  @relation(fields: [academicTermId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([studentId, academicTermId])
  @@map("student_fees")
}

/// Payment records
model Payment {
  id            BigInt              @id @default(autoincrement())
  studentId     BigInt
  amount        Int
  allocatedAmount Int             @default(0) // Sum of allocations for validation
  paymentDate   DateTime            @db.Date
  paymentMethod PaymentMethod
  receiptNo     String              // Unique per year
  termId        BigInt
  recordedBy    BigInt
  notes         String?             @db.Text
  status        PaymentStatus       @default(ACTIVE)
  voidReason    String?             @db.Text
  deletedAt     DateTime?           // Soft delete support
  allocations   PaymentAllocation[]
  receipt       Receipt?
  student       Student             @relation(fields: [studentId], references: [id])
  academicTerm  AcademicTerm        @relation(fields: [termId], references: [id])
  recordedByUser User              @relation(fields: [recordedBy], references: [id])
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([studentId])
  @@index([paymentDate])
  @@index([receiptNo])
  @@index([status])
  @@map("payments")
}

/// Payment allocation across fee types
model PaymentAllocation {
  id              BigInt        @id @default(autoincrement())
  paymentId       BigInt
  feeType         String        // debt, tuition, transport, stationery
  amountAllocated Int
  termId          BigInt
  payment         Payment       @relation(fields: [paymentId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([paymentId])
  @@map("payment_allocations")
}

/// Official receipt records
model Receipt {
  id             BigInt       @id @default(autoincrement())
  receiptNo      String       // RCP-2026-001
  academicYearId BigInt
  studentId      BigInt
  paymentId      BigInt       @unique
  issuedDate     DateTime     @db.Date
  issuedBy       BigInt
  pdfPath        String?
  student        Student      @relation(fields: [studentId], references: [id])
  payment        Payment      @relation(fields: [paymentId], references: [id])
  issuedByUser   User         @relation(fields: [issuedBy], references: [id])
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([receiptNo, academicYearId]) // Unique per academic year
  @@map("receipts")
}

/// Debt/arrears tracking
model DebtRecord {
  id            BigInt        @id @default(autoincrement())
  studentId     BigInt
  termId        BigInt
  amountOwed    Int
  dueDate       DateTime      @db.Date
  status        DebtStatus    @default(PENDING)
  notes         String?       @db.Text
  student       Student       @relation(fields: [studentId], references: [id])
  academicTerm  AcademicTerm  @relation(fields: [termId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([studentId])
  @@index([status])
  @@map("debt_records")
}

// ==================== TRANSPORT ====================

/// Transport service records
model Transport {
  id            BigInt         @id @default(autoincrement())
  studentId     BigInt         @unique
  monthlyRate   Int
  billingDay    Int            @default(1) // Day of month to bill
  startTermId   BigInt?
  endTermId     BigInt?
  status        TransportStatus @default(ACTIVE)
  vehicleDetails String?
  student       Student        @relation(fields: [studentId], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("transport")
}

// ==================== INVENTORY ====================

/// Inventory items (reams, files, uniforms, etc.)
model InventoryItem {
  id            BigInt            @id @default(autoincrement())
  name          String            @unique // Ream, File, Uniform, Kofia
  unitCost      Int
  stockQuantity Int
  reorderLevel  Int
  assignments   StudentInventory[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("inventory_items")
}

/// Stationery/items assigned to students
model StudentInventory {
  id          BigInt           @id @default(autoincrement())
  studentId   BigInt
  itemId      BigInt
  quantity    Int
  termId      BigInt
  isPaid      Boolean          @default(false)
  status      InventoryStatus  @default(PENDING)
  student     Student          @relation(fields: [studentId], references: [id])
  item        InventoryItem    @relation(fields: [itemId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([studentId, itemId, termId])
  @@map("student_inventory")
}

// ==================== PROMOTIONS ====================

/// Student class promotion history
model Promotion {
  id              BigInt        @id @default(autoincrement())
  studentId       BigInt
  fromClassId     BigInt
  toClassId       BigInt
  promotionDate   DateTime      @db.Date
  academicYearId  BigInt
  student         Student       @relation(fields: [studentId], references: [id])
  fromClass       Class         @relation("FromClass", fields: [fromClassId], references: [id])
  toClass         Class         @relation("ToClass", fields: [toClassId], references: [id])
  academicYear    AcademicYear  @relation(fields: [academicYearId], references: [id])
  createdAt       DateTime      @default(now())

  @@map("promotions")
}

// ==================== COMMENTS & LOGS ====================

/// Comments/notes on student accounts
model Comment {
  id          BigInt      @id @default(autoincrement())
  studentId   BigInt
  commentText String      @db.Text
  createdBy   BigInt
  student     Student     @relation(fields: [studentId], references: [id])
  createdByUser User      @relation(fields: [createdBy], references: [id])
  createdAt   DateTime    @default(now())

  @@index([studentId])
  @@map("comments")
}

/// System audit trail
model SystemLog {
  id          BigInt      @id @default(autoincrement())
  userId      BigInt
  action      String
  entityType  String
  entityId    BigInt
  timestamp   DateTime    @default(now())
  details     Json?
  user        User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([timestamp])
  @@index([entityType, entityId])
  @@map("system_logs")
}

/// Notification logs (SMS/Email)
model Notification {
  id         BigInt             @id @default(autoincrement())
  studentId  BigInt?
  guardianId BigInt?
  message    String             @db.Text
  channel    NotificationChannel
  status     NotificationStatus @default(PENDING)
  sentAt     DateTime?
  student    Student?           @relation(fields: [studentId], references: [id])
  guardian   Guardian?          @relation(fields: [guardianId], references: [id])
  createdAt  DateTime           @default(now())

  @@index([studentId])
  @@index([guardianId])
  @@index([status])
  @@map("notifications")
}
